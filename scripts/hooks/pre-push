#!/usr/bin/env bash
# Versioned pre-push hook. Activated via:
#   git config core.hooksPath scripts/hooks
#
# When pushing to a remote whose URL points at github.com, scans the
# commit range being pushed with gitleaks. Aborts the push on findings.
# Pushes to other remotes (GitLab origin) are unaffected.

set -euo pipefail

remote_name="$1"
remote_url="$2"

if [[ "$remote_url" != *"github.com"* ]]; then
    exit 0
fi

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "pre-push: gitleaks not installed but pushing to GitHub ($remote_name)." >&2
    echo "          Install it before pushing public — see scripts/publish-to-github.sh header." >&2
    exit 1
fi

zero="0000000000000000000000000000000000000000"
exit_code=0

while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$local_sha" == "$zero" ]]; then
        # Branch deletion — nothing to scan.
        continue
    fi

    if [[ "$remote_sha" == "$zero" ]]; then
        # New branch on remote — scan everything reachable from local_sha
        # that is not already on any other branch of this remote.
        range_args=("$local_sha" "--not")
        # shellcheck disable=SC2207
        others=($(git for-each-ref --format='%(refname)' "refs/remotes/${remote_name}/" || true))
        if (( ${#others[@]} > 0 )); then
            range_args+=("${others[@]}")
        fi
        log_range="${range_args[*]}"
    else
        log_range="${remote_sha}..${local_sha}"
    fi

    echo "pre-push: scanning $log_range with gitleaks..." >&2
    if ! gitleaks git --log-opts="$log_range" --config .gitleaks.toml --redact --no-banner; then
        echo "pre-push: gitleaks found potential secrets in $log_range — aborting push." >&2
        exit_code=1
    fi
done

exit "$exit_code"
